# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/retail_brain
#
# SQLite (local dev — used automatically if DATABASE_URL is not set):
# DATABASE_URL=sqlite:///data/retail_brain.db

# Set to "true" to print SQL queries (debug only)
SQL_ECHO=false

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── OpenAI (optional — rule-based fallback is used if not set) ────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# ── Phase 4: External Data Sources ────────────────────────────────────────
# OpenWeatherMap API (free tier: https://openweathermap.org/api)
# If not set, synthetic UK weather data is used as fallback.
OPENWEATHER_API_KEY=your_openweather_api_key_here
# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FORMAT: "text" for human-readable, "json" for structured production logs
LOG_FORMAT=text
